<div class="container my-5">
  <div class="row">
      <div class="">
        <div class="card border-0 shadow-sm mb-3" style="border-radius: 12px;">
          <div class="card-body p-4">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Trips Details</strong>
            </h5>

            <p class="card-text mb-2">
              <span class="text-muted">Departure</span>
              <span class="float-end fst-italic fw-light"><%= @plan.departure %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">Arrival</span>
              <span class="float-end fst-italic fw-light"><%= @plan.arrival %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">From</span>
              <span class="float-end fst-italic fw-light"><%= @plan.date_start %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">To</span>
              <span class="float-end fst-italic fw-light"><%= @plan.date_end %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">People</span>
              <span class="float-end fst-italic fw-light"><%= @plan.nb_people %></span>
            </p>
            <hr class="my-2">
            <div class="position-absolute bottom-0 start-0 p-3">
              <%= link_to "Edit",
                edit_plan_path(@plan),
                class: "btn btn-outline-warning btn-sm" %>
            </div>
            <div class="position-absolute bottom-0 end-0 p-3">
              <%= link_to "Remove",
                plan_path(@plan),
                data: { turbo_method: :delete,  turbo_confirm: "Are you sure?" },
                class: "btn btn-outline-danger btn-sm" %>
            </div>
          </div>
        </div>


        <div class="card border-0 shadow-sm mb-3" style="border-radius: 12px;">
          <div class="card-body p-4 position-relative">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Activities</strong>
            </h5>
            <% @plan.activities.each do |activity| %>
            <p class="card-text mb-2 d-flex justify-content-between align-items-start gap-2">
              <span class="text-muted text-nowrap">Type</span>
              <span class="float-end fst-italic fw-light text-end" style="word-break: break-word;">
                <%= activity.name %>
              </span>
            </p>

            <p class="card-text mb-2 d-flex justify-content-between align-items-start gap-2">
              <span class="text-muted text-nowrap">Price</span>
              <span class="float-end fst-italic fw-light text-end" style="word-break: break-word;">
                <%= activity.cost %></span>
            </p>
            <hr class="my-2">
            <%= link_to "Edit",
                edit_plan_activity_path(@plan, activity),
                class: "btn btn-outline-warning btn-sm" %>
            <% end %>

            <div class="position-absolute bottom-0 end-0 p-3">
              <%= link_to "Add",
                new_plan_activity_path(@plan),
                class: "btn btn-outline-success btn-sm" %>
            </div>
          </div>
        </div>


        <div class="card border-0 shadow-sm mb-3" style="border-radius: 12px;">
          <div class="card-body p-4 position-relative">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Transportation</strong>
            </h5>
            <% @plan.transports.each do |transport| %>
            <p class="card-text mb-2 d-flex justify-content-between align-items-start gap-2">
              <span class="text-muted text-nowrap">Type</span>
              <span class="float-end fst-italic fw-light text-end" style="word-break: break-word;">
                <%= transport.name %>
              </span>
            </p>

            <p class="card-text mb-2 d-flex justify-content-between align-items-start gap-2">
              <span class="text-muted">Price</span>
              <span class="float-end fst-italic fw-light text-end" style="word-break: break-word;">
                <%= transport.cost %></span>
            </p>
            <hr class="my-2">
            <%= link_to "Edit",
                edit_plan_transport_path(@plan, transport),
                class: "btn btn-outline-warning btn-sm" %>
            <% end %>
            <div class="position-absolute bottom-0 end-0 p-3">
              <%= link_to "Add",
                new_plan_transport_path(@plan),
                class: "btn btn-outline-success btn-sm" %>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm mb-3" style="border-radius: 12px;">
          <div class="card-body p-4 position-relative">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Accomodations</strong>
            </h5>
            <% @plan.logements.each do |logement| %>
            <p class="card-text mb-2 d-flex justify-content-between align-items-start gap-2">
              <span class="text-muted text-nowrap">Type</span>
              <span class="float-end fst-italic fw-light text-end" style="word-break: break-word;">
                <%= logement.name %>
              </span>
            </p>

            <p class="card-text mb-2 d-flex justify-content-between align-items-start gap-2">
              <span class="text-muted text-nowrap">Price</span>
              <span class="float-end fst-italic fw-light text-end" style="word-break: break-word;">
                <%= logement.cost %></span>
            </p>
            <hr class="my-2">
            <%= link_to "Edit",
                edit_plan_logement_path(@plan, logement),
                class: "btn btn-outline-warning btn-sm" %>
            <% end %>
            <div class="position-absolute bottom-0 end-0 p-3">
              <%= link_to "Add",
                new_plan_logement_path(@plan),
                class: "btn btn-outline-success btn-sm" %>
            </div>
          </div>
        </div>

      </div>
  </div>
</div>
