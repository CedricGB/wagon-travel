<div class="container my-5">
  <div class="row">
      <div class="">
        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
          <div class="card-body p-4">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Trips Details</strong>
            </h5>

            <p class="card-text mb-2">
              <span class="text-muted">Departure</span>
              <span class="float-end fst-italic fw-ligth"><%= @plan.departure %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">Arrival</span>
              <span class="float-end fst-italic fw-ligth"><%= @plan.arrival %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">From</span>
              <span class="float-end fst-italic fw-ligth"><%= @plan.date_start %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">To</span>
              <span class="float-end fst-italic fw-ligth"><%= @plan.date_end %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">People</span>
              <span class="float-end fst-italic fw-ligth"><%= @plan.nb_people %></span>
            </p>
            <hr class="my-2">
            <div class="position-absolute bottom-0 end-0 p-3">
              <%= link_to "Remove",
                plan_path(@plan),
                data: { turbo_method: :delete,  turbo_confirm: "Are you sure?" },
                class: "btn btn-outline-danger btn-sm" %>
            </div>
          </div>
        </div>


        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
          <div class="card-body p-4">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Activities</strong>
            </h5>
            <% @plan.activities.each do |activity| %>
            <p class="card-text mb-2">
              <span class="text-muted">Type</span>
              <span class="float-end fst-italic fw-ligth">
                <%= activity.name %>
              </span>
            </p>

            <p class="card-text mb-2">
              <span class="text-muted">Price</span>
              <span class="float-end fst-italic fw-ligth"><%= activity.cost %></span>
            </p>
            <hr class="my-2">
            <% end %>
          </div>
        </div>


        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
          <div class="card-body p-4">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Transportation</strong>
            </h5>
            <% @plan.transports.each do |transport| %>
            <p class="card-text mb-2">
              <span class="text-muted">Type</span>
              <span class="float-end fst-italic fw-ligth">
                <%= transport.name %>
              </span>
            </p>

            <p class="card-text mb-2">
              <span class="text-muted">Price</span>
              <span class="float-end fst-italic fw-ligth"><%= transport.cost %></span>
            </p>
            <hr class="my-2">
            <% end %>
          </div>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
          <div class="card-body p-4">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              <strong>Accomodations</strong>
            </h5>
            <% @plan.logements.each do |logement| %>
            <p class="card-text mb-2">
              <span class="text-muted">Type</span>
              <span class="float-end fst-italic fw-ligth">
                <%= logement.name %>
              </span>
            </p>

            <p class="card-text mb-2">
              <span class="text-muted">Price</span>
              <span class="float-end fst-italic fw-ligth"><%= logement.cost %></span>
            </p>
            <hr class="my-2">
            <% end %>
          </div>
        </div>

      </div>
  </div>
</div>
