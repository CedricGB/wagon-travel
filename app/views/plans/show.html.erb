<div class="container my-3">

  <div class="text-center mb-4">
    <h1><%= @plan.title %></h1>
  </div>

  <div class="d-flex gap-4">

    <div class="col-6">
      <%= render "card" %>
    </div>

    <div class="col-6 chat-container">

     <div class="chat-buttons d-flex justify-content-between mb-3">
      <%= button_to 'Create my accomodation',
      plan_messages_path(@plan),
      params: {message: {content: "Find my accomodation"}},
      class:"btn btn-outline-primary w-100 mx-1",
      data: {turbo_methood: :post}
      %>
      <%= button_to 'Create my activity',
      plan_messages_path(@plan),
      params: {message: {content: "Create an activity for me"}},
      class:"btn btn-outline-primary w-100 mx-1",
      data: {turbo_methood: :post}
      %>
      <%= button_to 'Create my transportation',
      plan_messages_path(@plan),
      params: {message: {content: "Create a suitable transportation for this trip"}},
      class:"btn btn-outline-primary w-100 mx-1",
      data: {turbo_methood: :post}
      %>

      </div>

      <div id="activities-result" class="mb-3">
        <p class="text-muted">Click to get suggestions</p>
      </div>

      <hr>

      <h2>Chat</h2>

<div id="new_message_container">
  <%= render "messages/form", plan: @plan , message: @message %>

</div>
      <div class="mt-3" id="messages_container">
  <%= render "messages/messages", messages: @messages %>
      </div>

    </div>

  </div>
</div>
