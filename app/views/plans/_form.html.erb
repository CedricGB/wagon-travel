<div class="container py-5">
  <div class="row">
    <div class="col-12 col-md-6 offset-lg-3">
      <div class="bg-white rounded p-3 shadow">
        <%= simple_form_for plan do |f| %>
          <%= f.input :title, placeholder: 'Voyage à Bali' %>
          <%= f.input :departure, placeholder: 'Paris' %>
          <%= f.input :arrival, placeholder: 'Bali' %>
          <%= f.input :date_start %>
          <%= f.input :date_end %>
          <%= f.input :budget %>
          <%= f.input :public, label: "Show the plan to everyone ? ", as: :boolean %>
          <%= f.submit class: 'btn btn-flat' %>
        <% end %>
      </div>
    </div>
  </div>
</div>
