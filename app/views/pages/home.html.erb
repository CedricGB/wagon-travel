<div class="hero text-center" style="background-image: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=2021&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');">
  <div class="container">
    <h1>Wagon Travel</h1>
    <p>Plan all your travels without having to worry about anything</p>
  </div>
    <% if user_signed_in? %>
      <div class="hero-buttons">
        <%= link_to "See people's plans", "#", class: "btn btn-light justify-content-start" %>
        <%= link_to "Add a plan", "/plans/new", class: "btn btn-light justify-content-end" %>
      </div>
    <% end %>

</div>
 <% if user_signed_in? %>
<div class="container my-5">
  <div class="row">
    <% @plans.each do |plan| %>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
          <div class="card-body p-4">
            <h5 class="mb-4 text-muted" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
              Trips Details
            </h5>

            <p class="card-text mb-2">
              <span class="text-muted">Departure</span>
              <span class="float-end fw-semibold"><%= plan.departure %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">Arrival</span>
              <span class="float-end fw semibold"><%= plan.arrival %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">From</span>
              <span class="float-end fw semibold"><%= plan.date_start %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">To</span>
              <span class="float-end fw semibold"><%= plan.date_end %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">People</span>
              <span class="float-end fw semibold"><%= plan.nb_people %></span>
            </p>
            <hr class="my-2">

            <p class="card-text mb-2">
              <span class="text-muted">Description</span>
              <span class="float-end fw semibold"><%= plan.content %></span>
            </p>
            <hr class="my-2">

            <div class="position-absolute bottom-0 end-0 p-3">
              <%= link_to "Remove",
                plan_path(plan),
                data: { turbo_method: :delete,  turbo_confirm: "Are you sure?" },
                class: "btn btn-outline-danger btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
    <div class="col-md-3">
      <div class="card h-100 text-center">
        <div class="card-body">
          <%= link_to "See all of my plans", "#", class: "btn btn-light w-100 mb-3" %>
          <% (@plans || []).last(3).each do |plan| %>
            <p><%= plan.title %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<% end %>
