<div class="hero text-center" style="background-image: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=2021&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');">
  <div class="container">
    <h1>Wagon Travel</h1>
    <p>Plan all your travels without having to worry about anything</p>
  </div>
    <% if user_signed_in? %>
      <div class="hero-buttons">
        <%= link_to "See people's plans", "/pages", class: "btn btn-light justify-content-start" %>
        <%= link_to "Add a plan", "/plans/new", class: "btn btn-outline-light justify-content-end" %>
      </div>
    <% end %>

</div>
 <% if user_signed_in? %>
<div class="container my-5">
  <div class="row">
    <% (@plan || []).each do |plan| %>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">plan.name</h5>
            <p class="card-text">plan.dates</p>
            <%= link_to "Remove", "#", class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    <% end %>
    <div class="col-md-3">
      <div class="card h-100 text-center">
        <div class="card-body">
          <%= link_to "See all of my plans", plans_path, class: "btn btn-light w-100 mb-3" %>
          <% (@plans || []).last(3).each do |plan| %>
            <p><%= plan.title %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<% end %>
